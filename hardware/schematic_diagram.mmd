graph TB

%% ============================================================
%% STYLES
%% ============================================================
classDef mcu fill:#1a1a2e,stroke:#e94560,stroke-width:3px,color:#fff,font-weight:bold
classDef bt fill:#0f3460,stroke:#53a8b6,stroke-width:2px,color:#fff
classDef sens fill:#1b4332,stroke:#52b788,stroke-width:2px,color:#fff
classDef mot fill:#7b2d26,stroke:#e07a5f,stroke-width:2px,color:#fff
classDef ui fill:#3d348b,stroke:#e6c229,stroke-width:2px,color:#fff
classDef pwr fill:#495057,stroke:#adb5bd,stroke-width:2px,color:#fff
classDef pas fill:#fff,stroke:#6c757d,stroke-width:1px,color:#333

%% ============================================================
%% POWER
%% ============================================================
subgraph PWR["POWER SUPPLY"]
    direction LR
    BAT1["BAT1 Logic 7.4V\n2x Murata 18650"]
    LM["LM2596 Step-Down"]
    V5["+5V Rail"]
    BAT2["BAT2 Traction 7.4V\n2x Samsung 25R"]
    BAT1 -->|"7.4V"| LM -->|"5V"| V5
end
class PWR pwr

%% ============================================================
%% MCU
%% ============================================================
subgraph MCU["ATmega328P Xplained Mini"]
    direction LR
    D0["D0/PD0 RX"]
    D1["D1/PD1 TX"]
    D2["D2/PD2"]
    D3["D3/PD3"]
    D4["D4/PD4"]
    D5["D5/PD5"]
    D6["D6/PD6 OC0A"]
    D7["D7/PD7"]
    D8["D8/PB0"]
    D9["D9/PB1"]
    D10["D10/PB2 OC1B"]
    A0["A0/PC0 ADC0"]
    A2["A2/PC2"]
    A4["A4/PC4 SDA"]
    A5["A5/PC5 SCL"]
end
class MCU mcu

%% ============================================================
%% BLUETOOTH
%% ============================================================
subgraph BT["HC-05 Bluetooth"]
    direction LR
    TX05["TX"]
    RX05["RX 3.3V"]
end
class BT bt

RDIV["Divider 1k + 2k\n5V to 3.3V"]:::pas

TX05 -->|"USART RX"| D0
D1 -->|"USART TX"| RDIV -->|"3.3V"| RX05

%% ============================================================
%% SENSORS
%% ============================================================
subgraph SF["HC-SR04 FRONT"]
    FT["TRIG"]
    FE["ECHO"]
end
class SF sens

subgraph SR["HC-SR04 REAR"]
    RT["TRIG"]
    RE["ECHO"]
end
class SR sens

D2 -->|"Trigger"| FT
FE -->|"Echo"| D3
D4 -->|"Trigger"| RT
RE -->|"Echo"| D5

%% ============================================================
%% L298N + STEERING
%% ============================================================
subgraph L298["L298N H-Bridge"]
    ENA["ENA PWM"]
    IN1["IN1"]
    IN2["IN2"]
end
class L298 mot

SM(("Steering Motor")):::mot

D6 -->|"PWM 0-255"| ENA
D8 -->|"Dir"| IN1
D9 -->|"Dir"| IN2
L298 --- SM

%% ============================================================
%% ESC + REAR MOTOR
%% ============================================================
subgraph ESC["ESC 20A"]
    SIG["Signal 50Hz"]
end
class ESC mot

RM(("Motor 390DC")):::mot

D10 -->|"OC1B 50Hz"| SIG
ESC --- RM

%% ============================================================
%% INTERFACE
%% ============================================================
subgraph LCD["LCD 1602 I2C"]
    SDA["SDA"]
    SCL["SCL"]
end
class LCD ui

BUZ["Buzzer TMB12A05"]:::ui
LDR["LDR + 10k Divider"]:::ui
R220["220 Ohm"]:::pas
LEDS(("2x LED Headlight")):::ui

A4 -->|"I2C SDA"| SDA
A5 -->|"I2C SCL"| SCL
A2 -->|"ON/OFF"| BUZ
LDR -->|"ADC0"| A0
D7 -->|"GPIO"| R220 --> LEDS

%% ============================================================
%% POWER CONNECTIONS
%% ============================================================
V5 -.->|"+5V"| MCU
V5 -.->|"+5V"| BT
V5 -.->|"+5V"| SF
V5 -.->|"+5V"| SR
V5 -.->|"+5V"| LCD
BAT1 -->|"7.4V"| L298
BAT2 -->|"7.4V"| ESC

%% ============================================================
%% GND BUS
%% ============================================================
GND["COMMON GND BUS\nMCU + BAT1 + BAT2 + ESC + L298N"]:::pwr

MCU -.->|"GND"| GND
L298 -.->|"GND"| GND
ESC -.->|"GND"| GND
BAT1 -.->|"GND"| GND
BAT2 -.->|"GND"| GND
