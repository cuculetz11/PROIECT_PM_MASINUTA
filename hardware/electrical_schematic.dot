digraph LandBuster {

    /* ─── GLOBAL ─── */
    rankdir=LR;
    splines=ortho;
    nodesep=0.9;
    ranksep=1.8;
    bgcolor=white;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=11, style=filled, fillcolor="#f0f0f0",
          shape=record, penwidth=1.5];
    edge [fontname="Helvetica", fontsize=9, penwidth=1.2];

    /* ═══════ POWER ═══════ */
    subgraph cluster_power {
        label="POWER SUPPLY"; style=dashed; color="#888888"; fontsize=13; fontcolor="#555555"; labeljust=l;

        BAT1 [label="{ BAT1 Logic Rail | 2x Murata 18650 | 7.4V 2600mAh 30A | {<pos>+7.4V|<neg>GND} }",
              fillcolor="#fff3e0", color="#e65100"];
        BAT2 [label="{ BAT2 Traction Rail | 2x Samsung 25R 18650 | 7.4V 2500mAh 8C | {<pos>+7.4V|<neg>GND} }",
              fillcolor="#fff3e0", color="#e65100"];
        LM2596 [label="{ {<vin>VIN|<gnd_in>GND} | LM2596 Step-Down | {<vout>+5V OUT|<gnd_out>GND} }",
                fillcolor="#e3f2fd", color="#1565c0"];
    }

    /* ═══════ MCU ═══════ */
    subgraph cluster_mcu {
        label="MICROCONTROLLER"; style=dashed; color="#e94560"; fontsize=13; fontcolor="#e94560"; labeljust=l;

        MCU [label="{ {<d0>D0/PD0 (RX)|<d1>D1/PD1 (TX)|<d2>D2/PD2|<d3>D3/PD3|<d4>D4/PD4|<d5>D5/PD5|<d6>D6/PD6 (OC0A)|<d7>D7/PD7|<d8>D8/PB0|<d9>D9/PB1|<d10>D10/PB2 (OC1B)} | ATmega328P\nXplained Mini | {<a0>A0/PC0 (ADC0)|<a2>A2/PC2|<a4>A4/PC4 (SDA)|<a5>A5/PC5 (SCL)|<vcc>VCC +5V|<gnd>GND} }",
             fillcolor="#1a1a2e", fontcolor="white", color="#e94560", penwidth=2.5];
    }

    /* ═══════ BLUETOOTH ═══════ */
    subgraph cluster_bt {
        label="BLUETOOTH"; style=dashed; color="#53a8b6"; fontsize=13; fontcolor="#0f3460"; labeljust=l;

        HC05 [label="{ {<tx>TX|<rx>RX (3.3V)|<vcc>VCC|<gnd>GND} | HC-05 Bluetooth }",
              fillcolor="#0f3460", fontcolor="white", color="#53a8b6"];
        DIVIDER [label="{ {<in>IN 5V} | Divider\nR1=1k  R2=2k\n5V to 3.3V | {<out>OUT 3.3V|<gnd>GND} }",
                 fillcolor="#ffffff", color="#888888", penwidth=1.0];
    }

    /* ═══════ SENSORS ═══════ */
    subgraph cluster_sens {
        label="ULTRASONIC SENSORS"; style=dashed; color="#52b788"; fontsize=13; fontcolor="#1b4332"; labeljust=l;

        SR04F [label="{ {<vcc>VCC|<trig>TRIG|<echo>ECHO|<gnd>GND} | HC-SR04 FRONT }",
               fillcolor="#1b4332", fontcolor="white", color="#52b788"];
        SR04R [label="{ {<vcc>VCC|<trig>TRIG|<echo>ECHO|<gnd>GND} | HC-SR04 REAR }",
               fillcolor="#1b4332", fontcolor="white", color="#52b788"];
    }

    /* ═══════ MOTORS ═══════ */
    subgraph cluster_mot {
        label="MOTOR CONTROL"; style=dashed; color="#e07a5f"; fontsize=13; fontcolor="#7b2d26"; labeljust=l;

        L298N [label="{ {<ena>ENA PWM|<in1>IN1|<in2>IN2|<v12>+7.4V|<gnd>GND} | L298N H-Bridge | {<out1>OUT1|<out2>OUT2} }",
               fillcolor="#7b2d26", fontcolor="white", color="#e07a5f"];
        STEER [label="Steering Motor\nDC 3-6V", shape=circle, fillcolor="#ffccbc", color="#7b2d26", width=1.2];
        ESC [label="{ {<sig>Signal|<bat>BAT+ 7.4V|<gnd>GND} | ESC 20A Brushed | {<mout>Motor Out} }",
             fillcolor="#7b2d26", fontcolor="white", color="#e07a5f"];
        REAR_M [label="Motor 390DC\n7.4V", shape=circle, fillcolor="#ffccbc", color="#7b2d26", width=1.2];
    }

    /* ═══════ INTERFACE ═══════ */
    subgraph cluster_ui {
        label="INTERFACE"; style=dashed; color="#e6c229"; fontsize=13; fontcolor="#3d348b"; labeljust=l;

        LCD [label="{ {<sda>SDA|<scl>SCL|<vcc>VCC|<gnd>GND} | LCD 1602 I2C\nPCF8574 }",
             fillcolor="#3d348b", fontcolor="white", color="#e6c229"];
        BUZZER [label="{ {<in>D+|<gnd>GND} | Buzzer TMB12A05 }",
                fillcolor="#3d348b", fontcolor="white", color="#e6c229"];
        LDR [label="{ {<vcc>+5V} | LDR + 10k Divider | {<out>Analog|<gnd>GND} }",
             fillcolor="#ffffff", color="#888888", penwidth=1.0];
        R220 [label="{ {<in>IN} | 220 Ohm | {<out>OUT} }",
              fillcolor="#ffffff", color="#888888", penwidth=1.0];
        LEDS [label="Headlights\n2x LED", shape=circle, fillcolor="#ffffcc", color="#3d348b", width=1.0];
    }

    /* ═══════ GND BUS ═══════ */
    GND_BUS [label="COMMON GND BUS  —  MCU + BAT1 + BAT2 + ESC + L298N",
             shape=rectangle, fillcolor="#333333", fontcolor="white", color="#000000", penwidth=2.5, width=5];

    /* ═══════ LEGEND ═══════ */
    subgraph cluster_legend {
        label="LEGEND"; style=filled; fillcolor="#fafafa"; color="#cccccc"; fontsize=12;
        node [shape=plaintext, fillcolor="#fafafa"];
        LEG [label=<
            <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="4">
            <TR><TD><FONT COLOR="#1565c0">——</FONT></TD><TD>Digital</TD></TR>
            <TR><TD><FONT COLOR="#2e7d32">——</FONT></TD><TD>PWM</TD></TR>
            <TR><TD><FONT COLOR="#7b1fa2">——</FONT></TD><TD>I2C</TD></TR>
            <TR><TD><FONT COLOR="#e65100">——</FONT></TD><TD>7.4V/Analog</TD></TR>
            <TR><TD><FONT COLOR="#d32f2f">——</FONT></TD><TD>+5V</TD></TR>
            <TR><TD><FONT COLOR="#000000">——</FONT></TD><TD>GND</TD></TR>
            </TABLE>
        >];
    }

    /* ═══════════════════════════════════════════════
       SIGNAL EDGES — xlabel for ortho compatibility
       ═══════════════════════════════════════════════ */

    /* Bluetooth USART */
    HC05:tx     -> MCU:d0       [xlabel="USART RX", color="#1565c0", fontcolor="#1565c0"];
    MCU:d1      -> DIVIDER:in   [xlabel="USART TX 5V", color="#1565c0", fontcolor="#1565c0"];
    DIVIDER:out -> HC05:rx      [xlabel="3.3V", color="#1565c0", fontcolor="#1565c0"];

    /* Ultrasonic Front */
    MCU:d2      -> SR04F:trig   [xlabel="TRIG", color="#1565c0", fontcolor="#1565c0"];
    SR04F:echo  -> MCU:d3       [xlabel="ECHO", color="#1565c0", fontcolor="#1565c0"];

    /* Ultrasonic Rear */
    MCU:d4      -> SR04R:trig   [xlabel="TRIG", color="#1565c0", fontcolor="#1565c0"];
    SR04R:echo  -> MCU:d5       [xlabel="ECHO", color="#1565c0", fontcolor="#1565c0"];

    /* L298N */
    MCU:d6      -> L298N:ena    [xlabel="PWM OC0A", color="#2e7d32", fontcolor="#2e7d32", penwidth=2];
    MCU:d8      -> L298N:in1    [xlabel="Dir IN1", color="#1565c0", fontcolor="#1565c0"];
    MCU:d9      -> L298N:in2    [xlabel="Dir IN2", color="#1565c0", fontcolor="#1565c0"];
    L298N:out1  -> STEER        [color="#7b2d26", penwidth=2.5];
    L298N:out2  -> STEER        [color="#7b2d26", penwidth=2.5];

    /* ESC */
    MCU:d10     -> ESC:sig      [xlabel="PWM OC1B 50Hz", color="#2e7d32", fontcolor="#2e7d32", penwidth=2];
    ESC:mout    -> REAR_M       [color="#7b2d26", penwidth=2.5];

    /* I2C */
    MCU:a4      -> LCD:sda      [xlabel="I2C SDA", color="#7b1fa2", fontcolor="#7b1fa2", style=bold];
    MCU:a5      -> LCD:scl      [xlabel="I2C SCL", color="#7b1fa2", fontcolor="#7b1fa2", style=bold];

    /* Analog LDR */
    LDR:out     -> MCU:a0       [xlabel="ADC0", color="#e65100", fontcolor="#e65100"];

    /* Buzzer */
    MCU:a2      -> BUZZER:in    [xlabel="ON/OFF", color="#1565c0", fontcolor="#1565c0"];

    /* LEDs */
    MCU:d7      -> R220:in      [xlabel="GPIO", color="#1565c0", fontcolor="#1565c0"];
    R220:out    -> LEDS         [color="#1565c0"];

    /* ═══════ POWER (orange 7.4V, red 5V) ═══════ */
    BAT1:pos    -> LM2596:vin   [xlabel="7.4V", color="#e65100", penwidth=2.5, fontcolor="#e65100"];
    LM2596:vout -> MCU:vcc      [xlabel="+5V", color="#d32f2f", penwidth=2, fontcolor="#d32f2f"];
    BAT1:pos    -> L298N:v12    [xlabel="7.4V", color="#e65100", penwidth=2.5, fontcolor="#e65100"];
    BAT2:pos    -> ESC:bat      [xlabel="7.4V", color="#e65100", penwidth=2.5, fontcolor="#e65100"];

    LM2596:vout -> HC05:vcc     [color="#d32f2f", style=dashed];
    LM2596:vout -> SR04F:vcc    [color="#d32f2f", style=dashed];
    LM2596:vout -> SR04R:vcc    [color="#d32f2f", style=dashed];
    LM2596:vout -> LCD:vcc      [color="#d32f2f", style=dashed];
    LM2596:vout -> LDR:vcc      [color="#d32f2f", style=dashed];

    /* ═══════ GND (black) ═══════ */
    MCU:gnd        -> GND_BUS   [color="#000000", penwidth=2];
    BAT1:neg       -> GND_BUS   [color="#000000", penwidth=2];
    BAT2:neg       -> GND_BUS   [color="#000000", penwidth=2];
    L298N:gnd      -> GND_BUS   [color="#000000", penwidth=2];
    ESC:gnd        -> GND_BUS   [color="#000000", penwidth=2];
    LM2596:gnd_out -> GND_BUS   [color="#000000", penwidth=2];
    HC05:gnd       -> GND_BUS   [color="#000000", penwidth=1.5, style=dashed];
    SR04F:gnd      -> GND_BUS   [color="#000000", penwidth=1.5, style=dashed];
    SR04R:gnd      -> GND_BUS   [color="#000000", penwidth=1.5, style=dashed];
    LCD:gnd        -> GND_BUS   [color="#000000", penwidth=1.5, style=dashed];
    BUZZER:gnd     -> GND_BUS   [color="#000000", penwidth=1.5, style=dashed];
    LDR:gnd        -> GND_BUS   [color="#000000", penwidth=1.5, style=dashed];
    DIVIDER:gnd    -> GND_BUS   [color="#000000", penwidth=1.5, style=dashed];
}
